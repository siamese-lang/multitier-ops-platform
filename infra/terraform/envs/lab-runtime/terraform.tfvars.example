# Copy this file to terraform.tfvars and fill in user-specific values.
# Do not commit terraform.tfvars because it can contain local access details.

aws_region    = "ap-northeast-2"
key_name      = "your-existing-ec2-keypair-name"
operator_cidr = "203.0.113.10/32"

project_name = "multitier-ops-platform"
environment  = "lab-runtime"

vpc_cidr            = "10.30.0.0/16"
public_subnet_cidr  = "10.30.1.0/24"
private_subnet_cidr = "10.30.11.0/24"

bastion_instance_type = "t3.micro"
app_instance_type     = "t3.small"
root_volume_size_gib  = 20

extra_tags = {
  Owner = "portfolio"
}
