all:
  vars:
    ansible_user: ubuntu
    ansible_ssh_private_key_file: /home/ubuntu-user/.ssh/my-web-key.pem
    ansible_ssh_common_args: >-
      -o IdentitiesOnly=yes
      -o StrictHostKeyChecking=accept-new
  children:
    bastion:
      hosts:
        bastion-01:
          ansible_host: <BASTION_PUBLIC_IP>
    app:
      vars:
        ansible_ssh_common_args: >-
          -o IdentitiesOnly=yes
          -o StrictHostKeyChecking=accept-new
          -o ProxyCommand="ssh -i /home/ubuntu-user/.ssh/my-web-key.pem -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -W %h:%p ubuntu@<BASTION_PUBLIC_IP>"
      hosts:
        app-01:
          ansible_host: <APP_PRIVATE_IP>
