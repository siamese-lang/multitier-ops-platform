# Managed by Ansible. Do not edit on the target host.

map $http_x_request_id $ops_request_id {
    default $http_x_request_id;
    ""      $request_id;
}

log_format ops_main 'time=$time_iso8601 '
                    'request_id=$ops_request_id '
                    'remote_addr=$remote_addr '
                    'host=$host '
                    'method=$request_method '
                    'uri="$request_uri" '
                    'status=$status '
                    'bytes=$body_bytes_sent '
                    'request_time=$request_time '
                    'upstream_addr="$upstream_addr" '
                    'upstream_status="$upstream_status" '
                    'upstream_response_time="$upstream_response_time" '
                    'upstream_connect_time="$upstream_connect_time" '
                    'upstream_header_time="$upstream_header_time" '
                    'referer="$http_referer" '
                    'user_agent="$http_user_agent"';

upstream {{ nginx_ops_upstream_name }} {
    {{ nginx_ops_upstream_method }};
{% for host in groups['app'] | default([]) %}
    server {{ hostvars[host].ansible_host }}:{{ nginx_ops_app_port }} max_fails={{ nginx_ops_upstream_max_fails }} fail_timeout={{ nginx_ops_upstream_fail_timeout }};
{% endfor %}
    keepalive {{ nginx_ops_upstream_keepalive }};
}

server {
    listen {{ nginx_ops_http_port }};
    server_name {{ nginx_ops_server_name }};

    access_log {{ nginx_ops_access_log }} ops_main;
    error_log {{ nginx_ops_error_log }} warn;

    return 301 https://$host$request_uri;
}

server {
    listen {{ nginx_ops_https_port }} ssl;
    server_name {{ nginx_ops_server_name }};

    ssl_certificate {{ nginx_ops_ssl_cert }};
    ssl_certificate_key {{ nginx_ops_ssl_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    access_log {{ nginx_ops_access_log }} ops_main;
    error_log {{ nginx_ops_error_log }} warn;

    add_header X-Request-Id $ops_request_id always;

    location = /nginx-healthz {
        access_log off;
        return 200 "nginx ok\n";
    }

    location / {
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header X-Request-Id $ops_request_id;

        proxy_connect_timeout {{ nginx_ops_proxy_connect_timeout }};
        proxy_send_timeout {{ nginx_ops_proxy_send_timeout }};
        proxy_read_timeout {{ nginx_ops_proxy_read_timeout }};
        proxy_next_upstream {{ nginx_ops_proxy_next_upstream }};
        proxy_next_upstream_tries {{ nginx_ops_proxy_next_upstream_tries }};

        proxy_pass http://{{ nginx_ops_upstream_name }};
    }
}
